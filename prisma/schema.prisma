generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  savedScripts  SavedScript[]
  resetTokens   PasswordResetToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Script {
  id               String   @id @default(cuid())
  title            String
  author           String
  pageCount        Int
  sceneCount       Int      @default(1)
  thumbnailUrl     String
  category         String
  genre            String
  length           String
  era              String
  durationLabel    String
  description      String
  sceneId          String
  sceneTitle       String
  previewText      String
  trendingScore    Float    @default(0)
  // Provenance / public-domain verification
  sourceName       String   @default("")
  sourceUrl        String   @default("")
  verificationNote String   @default("")
  // Cloud-stored asset (populated by scripts:import-assets)
  assetUrl         String?  // full public URL of the stored object
  assetObjectKey   String?  // bucket object key, e.g. "scripts/1513.txt"
  assetFormat      String?  // "plain-text"
  assetMimeType    String?  // "text/plain; charset=utf-8"
  assetByteSize    Int?     // byte size of uploaded content
  assetSourceUrl   String?  // Gutenberg text URL used for download
  assetValidatedAt DateTime? // timestamp of last successful validate+upload
  createdAt        DateTime @default(now())

  savedBy    SavedScript[]
  characters ScriptCharacter[]
  scenes     ScriptScene[]
}

// Normalized parsed-script data (populated by the script-store persistence layer)

model ScriptCharacter {
  id       String @id @default(cuid())
  scriptId String
  name     String

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, name])
}

model ScriptScene {
  id       String  @id @default(cuid())
  scriptId String
  index    Int     // zero-based position in the script
  heading  String  // raw heading text, e.g. "INT. COFFEE SHOP - DAY"
  title    String? // AI-generated short title; null until extraction runs

  script Script       @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  lines  ScriptLine[]

  @@unique([scriptId, index])
}

model ScriptLine {
  id        String  @id @default(cuid())
  sceneId   String
  lineIndex Int     // zero-based position within the scene
  type      String  // dialogue | action | character | parenthetical | transition | lyrics | other
  text      String
  character String? // set for dialogue and parenthetical lines

  scene ScriptScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([sceneId])
}

model SavedScript {
  id       String   @id @default(cuid())
  userId   String
  scriptId String
  savedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([userId, scriptId])
}
