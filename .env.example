DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="your-access-token-secret-here"
JWT_REFRESH_SECRET="your-refresh-token-secret-here"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
PORT=3100

# OpenAI script extraction (task 80)
OPENAI_API_KEY=
OPENAI_SCRIPT_EXTRACTION_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Cloud storage — S3-compatible (AWS S3 / Cloudflare R2 / Backblaze B2 / MinIO)
# Required to run:  npm run scripts:import-assets
# ---------------------------------------------------------------------------

# Bucket name (required)
STORAGE_BUCKET=

# Region — use "auto" for Cloudflare R2, a real region for AWS S3 / Backblaze B2
STORAGE_REGION=auto

# Access credentials (required)
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# Custom S3-compatible endpoint URL — omit this for native AWS S3.
#   Cloudflare R2 : https://<account-id>.r2.cloudflarestorage.com
#   Backblaze B2  : https://s3.<region>.backblazeb2.com
#   MinIO (local) : http://localhost:9000
STORAGE_ENDPOINT=

# Optional: CDN or custom domain URL prefix for building public asset URLs.
# If unset, URLs are derived from STORAGE_ENDPOINT or the AWS S3 default.
#   Example: https://assets.yourapp.com
STORAGE_PUBLIC_BASE_URL=
